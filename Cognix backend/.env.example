# ============================================================
# Cognix Backend - Environment Configuration Example
# Copy this file to .env and fill in your actual values
# ============================================================

# --- Database (MySQL 8.0) ---
# Format: mysql+aiomysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/cognix

# --- Redis 7 ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Application ---
APP_NAME=Cognix
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# --- CORS ---
# Comma-separated list of allowed origins (frontend dev server)
CORS_ORIGINS=http://localhost:5173

# --- OpenAI (Phase 2, set when needed) ---
OPENAI_API_KEY=

# --- File Storage (Phase 2) ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
